# LLM Provider
# Default: Ollama running locally (no API key needed)
# For OpenAI: set LLM_BASE_URL=https://api.openai.com/v1 and LLM_API_KEY=sk-your-key
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=research_papers

# Redis (optional, falls back to in-memory cache)
REDIS_URL=
CACHE_TTL=3600

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Monitoring
ENABLE_TRACING=true
